# Copy this file to .env before public or production deployment.

POSTGRES_DB=nrunmesh
POSTGRES_USER=nrunmesh
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432

CONTROLLER_BIND_HOST=0.0.0.0
CONTROLLER_PORT=3012
APP_TIMEZONE=UTC

SECRET_KEY=replace-with-a-long-random-secret
NRUNMESH_ADMIN_USER=admin
NRUNMESH_ADMIN_PASSWORD=replace-with-a-strong-admin-password
NRUNMESH_ADMIN_NAME=N-RunMesh Administrator

# Use the same key when installing every agent.
CRON_AGENT_API_KEY=replace-with-a-long-random-agent-key
CRON_AGENT_HTTP_PORT=8765
CRON_AGENT_TTL=60

# Host folder mounted into Controller and automatic backup worker.
# May be relative to compose.yml or an absolute host path.
BACKUP_HOST_PATH=./backups
